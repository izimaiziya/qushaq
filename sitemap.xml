<?xml version="1.0" encoding="UTF-8"?>
<!--
  Qushaq — sitemap.xml

  This is a single-page site (index.html), so there's only one URL to
  list — Google doesn't index #anchors as separate pages. The hreflang
  entries tell Google that the RU/EN/KK versions are the same page with
  a switchable language, not duplicate content.

  IMPORTANT: replace https://qushaq.app/ below with your real domain
  once the site is deployed (this is a placeholder based on your
  Instagram handle @qushaq.app). Update <lastmod> whenever you make a
  meaningful content change.
-->
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:xhtml="http://www.w3.org/1999/xhtml">
  <url>
    <loc>https://qushaq.app/</loc>
    <lastmod>2026-07-14</lastmod>
    <changefreq>weekly</changefreq>
    <priority>1.0</priority>
    <xhtml:link rel="alternate" hreflang="ru" href="https://qushaq.app/"/>
    <xhtml:link rel="alternate" hreflang="en" href="https://qushaq.app/"/>
    <xhtml:link rel="alternate" hreflang="kk" href="https://qushaq.app/"/>
    <xhtml:link rel="alternate" hreflang="x-default" href="https://qushaq.app/"/>
  </url>
</urlset>
